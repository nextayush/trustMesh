{
  "policyName": "Supplier View Access Rule",
  "resource": "shipment",
  "action": "VIEW_MANIFEST",
  "conditions": [
    {
      "attribute": "role",
      "operator": "EQUALS",
      "value": "SUPPLIER"
    },
    {
      "attribute": "clearanceLevel",
      "operator": "GREATER_THAN_OR_EQUAL",
      "value": "2"
    }
  ]
}
